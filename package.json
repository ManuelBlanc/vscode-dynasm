{
  "name": "dynasm-lang",
  "displayName": "Provides snippets, syntax highlighting, bracket matching and folding in C# files.",
  "author": {
    "name": "ManuelBlanc"
  },
  "description": "Syntax highlighting for DynASM",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/vscode.git"
  },
  "engines": {
    "vscode": "^1.39.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "dynasm",
        "aliases": [
          "DynASM",
          "dynasm"
        ],
        "extensions": [
          ".dasc",
          ".dash"
        ],
        "configuration": "./dist/dynasm.language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "dynasm",
        "scopeName": "source.c.dynasm",
        "path": "./dist/dynasm.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "dynasm",
        "path": "./dist/dynasm.code-snippets"
      }
    ]
  },
  "scripts": {
    "package": "npm run format && vsce package",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.2",
    "prettier": "^3.8.3"
  }
}
